{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range .Data.Pages }}
  {{- /* Exclude thin/utility pages from sitemap to focus crawl budget */ -}}
  {{- if not (hasPrefix .RelPermalink "/tags/") }}
  {{- if not (eq .RelPermalink "/search/") }}
  {{- if not (eq .RelPermalink "/thank-you/") }}
  {{- if not (eq .RelPermalink "/categories/") }}
  {{- /* Skip paginator pages (page/2, page/3, etc.) */ -}}
  {{- if not (in .RelPermalink "/page/") }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ safeHTML ( .Lastmod.Format "2006-01-02T15:04:05-07:00" ) }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
  </url>
  {{- end }}
  {{- end }}
  {{- end }}
  {{- end }}
  {{- end }}
  {{- end }}
</urlset>
